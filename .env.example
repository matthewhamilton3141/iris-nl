# Copy to .env and fill in. Nothing here is required to try the offline demo:
#   IRIS_NL_PROVIDER=mock npm run dev -- "undo my last commit"

# Which brain to use: nvidia | ollama | tensorrt | mock | auto (default: auto)
# auto = use NVIDIA if NVIDIA_API_KEY is set, otherwise fall back to Ollama.
IRIS_NL_PROVIDER=auto

# --- NVIDIA free hosted API (build.nvidia.com) ---
# Get a free key (no credit card) at https://build.nvidia.com
NVIDIA_API_KEY=
# Any chat model slug from build.nvidia.com. Nemotron models are NVIDIA's own and on-brand.
IRIS_NL_NVIDIA_MODEL=meta/llama-3.1-8b-instruct
IRIS_NL_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Local Ollama (https://ollama.com) ---
# After `ollama pull llama3.2`, no key needed and it runs fully offline.
IRIS_NL_OLLAMA_MODEL=llama3.2
IRIS_NL_OLLAMA_BASE_URL=http://localhost:11434

# --- Local TensorRT-LLM (stage 2: your own optimized model) ---
# Start it on the GPU box: `trtllm-serve ./trt_engine --port 8000`
# OpenAI-compatible, local, no key. IRIS_NL_TENSORRT_MODEL = the served model name.
IRIS_NL_TENSORRT_MODEL=tensorrt-llm
IRIS_NL_TENSORRT_BASE_URL=http://localhost:8000/v1
